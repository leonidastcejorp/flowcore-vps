{
  "//": "🔥 BREACH Cron Jobs — Reference config",
  "//2": "This is a snapshot for migration reference.",
  "//3": "To deploy on a new VPS, run: bash deploy-cron.sh",
  "//4": "That script uses 'hermes cron create' for each job.",
  "jobs_schedule": {
    "hourly": {
      "00": "📈 MemStat — memory_monitor.py",
      "15": "🔁 Bootmark — reboot_monitor.py",
      "30": "📊 Session Deck — context_monitor.py"
    },
    "every_6h": {
      "00": "📀 DiskBay — disk_alert.sh",
      "10": "💰 Cuan Feed — income_pipeline.py",
      "20": "🚪 PortGuard — ssh_attack_monitor.py",
      "30": "📡 VitalSign — monitor.py",
      "40": "📋 LogDesk — error_summary.py",
      "50": "🔄 Proxy — proxy_updater.py (local)"
    },
    "fixed": {
      "16:00 daily":     "📊 Daily Briefing — daily_report.py",
      "Mon 03:00":       "🧹 Session Prune — prune.sh (local)",
      "Sun 02:00":       "💾 Weekly Backup — vps_backup.sh (local)"
    }
  },
  "all_no_agent": true,
  "delivery": "telegram:-1003534226714 (Kantor FBI group)",
  "state_files": {
    "memory_monitor.py":     "~/.hermes/scripts/.memory_state.json",
    "reboot_monitor.py":     "~/.hermes/scripts/.boot_state.json",
    "context_monitor.py":    "~/.hermes/scripts/.context_thresholds.json",
    "error_summary.py":      "~/.hermes/scripts/.error_summary_state.json"
  },
  "output_dirs": {
    "/root/projects/bounty-output/": "Income pipeline cache + error reports",
    "/root/projects/bounty-output/proxies/": "Proxy pool files"
  }
}
